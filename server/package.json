{
  "name": "splitwise-clone-server",
  "version": "1.0.0",
  "description": "Splitwise Clone Backend — Node.js + Express + Prisma + Socket.io",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --runInBand",
    "test:unit": "node --experimental-vm-modules node_modules/.bin/jest tests/unit --runInBand",
    "test:integration": "node --experimental-vm-modules node_modules/.bin/jest tests/integration --runInBand",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "import": "node scripts/importCsv.js"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {}
  },
  "keywords": [],
  "author": "Spreetail Intern",
  "license": "ISC",
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "csv-parser": "^3.2.1",
    "dayjs": "^1.11.21",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "multer": "^2.1.1",
    "prisma": "^6.19.3",
    "socket.io": "^4.8.3"
  }
}
